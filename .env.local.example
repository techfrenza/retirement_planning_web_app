# LLM Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# --- Anthropic via SAP Hyperspace proxy ---
# Uses Authorization: Bearer <token> (NOT x-api-key)
ANTHROPIC_AUTH_TOKEN=30144421-ee39-4b56-b728-d9a744954723
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/

# --- Anthropic direct (fallback when ANTHROPIC_AUTH_TOKEN is not set) ---
ANTHROPIC_API_KEY=

# --- Anthropic model override ---
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
